# Root development defaults. Copy to .env for local work.

# Backend
ONEEPIS_ENVIRONMENT=development
ONEEPIS_DATABASE_URL=postgresql+psycopg://oneepis:oneepis@localhost:5433/oneepis
ONEEPIS_CORS_ORIGINS=["http://localhost:3000"]
ONEEPIS_AI_PROVIDER=ollama
ONEEPIS_OLLAMA_BASE_URL=http://localhost:11434
ONEEPIS_OLLAMA_MODEL=llama3.2:latest
ONEEPIS_OLLAMA_MODEL_SUMMARY=qwen3:8b
ONEEPIS_OLLAMA_MODEL_SUGGESTIONS=qwen3:8b
ONEEPIS_OLLAMA_MODEL_EMBEDDINGS=bge-m3
ONEEPIS_OLLAMA_TIMEOUT_SECONDS=60

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_ONEEPIS_ACTOR=web.dev
NEXT_PUBLIC_DEMO_MODE=false
