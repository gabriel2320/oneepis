# Root development defaults. Copy to .env for local work.

# Backend
ONEEPIS_ENVIRONMENT=development
ONEEPIS_DATABASE_URL=postgresql+psycopg://oneepis:oneepis@localhost:5433/oneepis
ONEEPIS_CORS_ORIGINS=["http://localhost:3000"]
ONEEPIS_AI_PROVIDER=ollama
ONEEPIS_OLLAMA_BASE_URL=http://localhost:11434
ONEEPIS_OLLAMA_MODEL=llama3.2:latest
ONEEPIS_OLLAMA_MODEL_SUMMARY=qwen3:8b
ONEEPIS_OLLAMA_MODEL_SUGGESTIONS=qwen3:8b
ONEEPIS_OLLAMA_MODEL_EMBEDDINGS=bge-m3
ONEEPIS_OLLAMA_TIMEOUT_SECONDS=60
ONEEPIS_AUTH_ENABLED=true
ONEEPIS_AUTH_SECRET=change-this-local-secret
ONEEPIS_AUTH_TOKEN_TTL_MINUTES=720
ONEEPIS_AUTH_SESSION_COOKIE_NAME=oneepis_session
ONEEPIS_AUTH_CSRF_COOKIE_NAME=oneepis_csrf
ONEEPIS_AUTH_ALLOW_DEV_ACTOR_HEADER=false
ONEEPIS_AUTH_LOCAL_USERS=admin@oneepis.local|admin|Administrador Dev|admin,dev;medico@oneepis.local|medico|Medico Dev|medico;enfermeria@oneepis.local|enfermeria|Enfermeria Dev|enfermeria;lector@oneepis.local|lector|Lectura Dev|solo_lectura
ONEEPIS_AUTH_LOGIN_MAX_FAILED_ATTEMPTS=5
ONEEPIS_AUTH_LOGIN_WINDOW_SECONDS=900
ONEEPIS_AUTH_LOGIN_LOCK_SECONDS=900
ONEEPIS_AUTH_RECOVERY_TOKEN_TTL_MINUTES=30
ONEEPIS_AUTH_RECOVERY_MAX_REQUESTS=3
ONEEPIS_AUTH_RECOVERY_WINDOW_SECONDS=3600
ONEEPIS_AUTH_NOTIFICATION_PROVIDER=disabled
ONEEPIS_AUTH_PUBLIC_WEB_BASE_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Optional only when ONEEPIS_AUTH_ALLOW_DEV_ACTOR_HEADER=true.
NEXT_PUBLIC_ONEEPIS_ACTOR=
NEXT_PUBLIC_DEMO_MODE=false
